---
import "../styles/app.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import BackgroundImage from "@components/Background.astro";

interface Props {
	title?: string;
}

const { title } = Astro.props;
const pageTitle = title ? `${title} | unearth.club` : "unearth.club";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#faf8f5" />
		<link rel="preload" href="/UT Bekidos.ttf" as="font" type="font/truetype" crossorigin />
		<link rel="preload" href="/FacultyGlyphic-Regular.ttf" as="font" type="font/truetype" crossorigin />
		<title>{pageTitle}</title>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<BackgroundImage>
			<header class="header">
				<a href="/" class="logo">
					<h1>unearth.club</h1>
				</a>
				<nav class="nav">
					<a href="/" class="nav-link">discoveries</a>
					<a href="/submit" class="nav-link">submit</a>
				</nav>
			</header>
			<main id="main-content" class="main">
				<slot />
			</main>
		</BackgroundImage>
		<Analytics />
		<SpeedInsights />
	</body>
</html>

<style>
	@reference "@styles/app.css";

	.skip-link {
		position: absolute;
		top: -100%;
		left: 1rem;
		z-index: 100;
		padding: 0.5rem 1rem;
		background: var(--color-accent);
		color: var(--color-bg-primary);
		border-radius: 0.375rem;
		text-decoration: none;
		font-family: "Faculty Glyphic", sans-serif;
	}

	.skip-link:focus {
		top: 1rem;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	.header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.logo {
		text-decoration: none;
	}

	.logo h1 {
		@apply text-4xl sm:text-5xl;
		margin: 0;
	}

	.nav {
		display: flex;
		gap: 1.5rem;
	}

	.nav-link {
		font-family: "Faculty Glyphic", sans-serif;
		color: var(--color-text-secondary);
		text-decoration: none;
		@apply text-lg;
		transition: color 0.2s ease;
	}

	.nav-link:hover {
		color: var(--color-accent-dark);
	}

	.main {
		max-width: 64rem;
		margin: 0 auto;
		padding: 2rem 1rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		align-items: center;
	}
</style>
