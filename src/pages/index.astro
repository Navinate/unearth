---
export const prerender = true;

import Layout from "../layouts/BaseLayout.astro";
import { getCurrentWeekMedia } from "../lib/notion";
import WeekIndicator from "@components/WeekIndicator.astro";
import EmptyState from "@components/EmptyState.astro";
import MediaCard from "@components/MediaCard.astro";

const pages = await getCurrentWeekMedia();
---

<Layout title="unearth.club — Weekly Media Discoveries" description="Browse this week's curated media recommendations — videos, articles, music, and more worth sharing.">
	<WeekIndicator />

	{
		pages.length > 0 ? (
			<div class="media-grid">
				{pages.map((page) => (
					<MediaCard page={page} />
				))}
			</div>
		) : (
			<EmptyState />
		)
	}

	{
		pages.length > 0 && (
			<div class="cta">
				<a href="/submit" class="btn">
					Know something worth sharing?
				</a>
			</div>
		)
	}
</Layout>

<style>
	@reference "@styles/app.css";

	.media-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		width: 100%;
	}

	@media (min-width: 768px) {
		.media-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.cta {
		text-align: center;
		padding: 2rem 0;
	}
</style>

<script>
	// Track the element that triggered the modal so we can restore focus on close
	let triggerElement: HTMLElement | null = null;

	// Open modal when card is clicked
	document
		.querySelectorAll<HTMLElement>("[data-modal-target]")
		.forEach((card) => {
			card.addEventListener("click", () => {
				const modalId = card.dataset.modalTarget;
				if (!modalId) return;
				const dialog = document.getElementById(
					modalId,
				) as HTMLDialogElement | null;
				if (dialog) {
				triggerElement = card;
				dialog.showModal();
				}
		});
		});

	// Close modal via close button
	document
		.querySelectorAll<HTMLElement>("[data-modal-close]")
		.forEach((btn) => {
			btn.addEventListener("click", () => {
				const dialog = btn.closest("dialog") as HTMLDialogElement | null;
				dialog?.close();
			});
		});

	// Close modal on backdrop click and restore focus on close
	document
		.querySelectorAll<HTMLDialogElement>("dialog.media-modal")
		.forEach((dialog) => {
			dialog.addEventListener("click", (e) => {
				if (e.target === dialog) {
					dialog.close();
				}
			});
	
		dialog.addEventListener("close", () => {
			triggerElement?.focus();
			triggerElement = null;
		});
	});
</script>
