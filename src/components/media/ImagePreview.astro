---
interface Props {
	src: string;
	alt: string;
}

const { src, alt } = Astro.props;
---

<div class="image-preview">
	<img src={src} alt={alt} loading="lazy" />
</div>

<style>
	@reference "@styles/app.css";

	.image-preview {
		width: 100%;
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.image-preview img {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
		max-height: 400px;
	}
</style>
