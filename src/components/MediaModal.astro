---
import type { Page } from "@types/index";
import MediaTypeBadge from "./MediaTypeBadge.astro";
import VideoEmbed from "./media/VideoEmbed.astro";
import AudioEmbed from "./media/AudioEmbed.astro";
import ImagePreview from "./media/ImagePreview.astro";
import { parseVideoEmbed, parseAudioEmbed, isDirectImageUrl, extractDomain } from "@lib/embedHelpers";

interface Props {
	page: Page;
	modalId: string;
}

const { page, modalId } = Astro.props;

const videoEmbed = page.mediaType === "Video" ? parseVideoEmbed(page.link) : null;
const audioEmbed = page.mediaType === "Audio" ? parseAudioEmbed(page.link) : null;
const isImage = page.mediaType === "Image" && isDirectImageUrl(page.link);
const hasCover = !!page.coverImage;
const domain = extractDomain(page.link);
---

<dialog id={modalId} class="media-modal">
	<div class="modal-content">
		<button class="close-btn" data-modal-close aria-label="Close">
			<svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
				<line x1="4" y1="4" x2="16" y2="16" />
				<line x1="16" y1="4" x2="4" y2="16" />
			</svg>
		</button>

		{hasCover && (
			<div class="modal-cover">
				<img src={page.coverImage} alt={page.title} />
			</div>
		)}

		<div class="modal-body">
			<div class="modal-header">
				<MediaTypeBadge type={page.mediaType} />
				{page.creator && <span class="modal-creator">{page.creator}</span>}
			</div>

			<h2 class="modal-title">{page.title}</h2>

			{page.content && <p class="modal-description">{page.content}</p>}

			<div class="modal-embed">
				{videoEmbed?.embedUrl ? (
					<VideoEmbed embedUrl={videoEmbed.embedUrl} title={page.title} />
				) : audioEmbed?.embedUrl ? (
					<AudioEmbed embedUrl={audioEmbed.embedUrl} provider={audioEmbed.provider!} title={page.title} />
				) : isImage && !hasCover ? (
					<ImagePreview src={page.link} alt={page.title} />
				) : null}
			</div>

			<a href={page.link} target="_blank" rel="noopener noreferrer" class="source-link">
				<span class="source-label">View source</span>
				{domain && <span class="source-domain">{domain}</span>}
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5">
					<path d="M6 2H2v10h10V8M8 2h4v4M7 7l5-5" />
				</svg>
			</a>

			{page.submitter && (
				<p class="modal-submitter">submitted by {page.submitter}</p>
			)}
		</div>
	</div>
</dialog>

<style>
	@reference "@styles/app.css";

	.media-modal {
		border: none;
		border-radius: 0.75rem;
		padding: 0;
		max-width: 40rem;
		width: calc(100% - 2rem);
		max-height: calc(100vh - 4rem);
		overflow: hidden;
		background: var(--color-bg-primary);
		box-shadow: var(--shadow-l);
		color: var(--color-text-primary);
	}

	.media-modal::backdrop {
		background: rgba(44, 44, 44, 0.5);
		backdrop-filter: blur(4px);
	}

	.media-modal[open] {
		display: flex;
		flex-direction: column;
	}

	.modal-content {
		position: relative;
		overflow-y: auto;
		overscroll-behavior: contain;
	}

	.close-btn {
		all: unset;
		cursor: pointer;
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		z-index: 10;
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: var(--color-bg-primary);
		color: var(--color-text-secondary);
		box-shadow: var(--shadow-s);
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.close-btn:hover {
		background: var(--color-bg-tertiary);
		color: var(--color-text-primary);
	}

	.close-btn:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 2px;
	}

	.modal-cover {
		width: 100%;
		overflow: hidden;
	}

	.modal-cover img {
		width: 100%;
		max-height: 400px;
		object-fit: cover;
		display: block;
	}

	.modal-body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.modal-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.modal-creator {
		font-family: "Faculty Glyphic", sans-serif;
		color: var(--color-text-secondary);
		@apply text-base;
	}

	.modal-title {
		@apply text-2xl sm:text-3xl;
		font-family: "Faculty Glyphic", sans-serif;
		color: var(--color-text-primary);
		margin: 0;
		line-height: 1.2;
	}

	.modal-description {
		color: var(--color-text-secondary);
		@apply text-base;
		margin: 0;
		line-height: 1.6;
	}

	.modal-embed {
		margin: 0.5rem 0;
	}

	.modal-embed:empty {
		display: none;
	}

	.source-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.6rem 1rem;
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		background: var(--color-bg-secondary);
		text-decoration: none;
		transition:
			background 0.15s ease,
			border-color 0.15s ease;
		align-self: flex-start;
	}

	.source-link:hover {
		background: var(--color-bg-tertiary);
		border-color: var(--color-accent-light);
	}

	.source-label {
		font-family: "Faculty Glyphic", sans-serif;
		color: var(--color-accent-dark);
		@apply text-sm;
	}

	.source-domain {
		color: var(--color-text-muted);
		@apply text-xs;
	}

	.source-link svg {
		color: var(--color-text-muted);
		flex-shrink: 0;
	}

	.modal-submitter {
		color: var(--color-text-muted);
		@apply text-sm;
		font-style: italic;
		margin: 0;
	}
</style>
