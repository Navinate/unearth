---
import { actions } from "astro:actions";
---

<form
	method="POST"
	action={actions.submitToNotion}
	class="form-grid"
>
	<fieldset class="fieldset">
		<legend class="fieldset-legend">what do you call the media?</legend>
		<input type="text" name="title" required placeholder="Mona Lisa" class="input" />
	</fieldset>

	<fieldset class="fieldset">
		<legend class="fieldset-legend">what medium is the media?</legend>
		<select name="mediaType" required class="select">
			<option disabled selected hidden value="">Select media type</option>
			<option value="Text">Text</option>
			<option value="Video">Video</option>
			<option value="Audio">Audio</option>
			<option value="Image">Image</option>
			<option value="Interactive">Interactive</option>
			<option value="Other">???</option>
		</select>
	</fieldset>

	<fieldset class="fieldset">
		<legend class="fieldset-legend">link to the media?</legend>
		<input
			type="url"
			name="link"
			required
			placeholder="https://"
			class="input"
		/>
	</fieldset>

	<fieldset class="fieldset">
		<legend class="fieldset-legend">what is your name?</legend>
		<input type="text" name="name" class="input" placeholder="optional" />
		<p class="label">if you want to be credited for submission</p>
	</fieldset>

	<fieldset class="fieldset sm:col-span-2 w-full">
		<legend class="fieldset-legend">describe why your submission is awesome!</legend>
		<textarea
			name="description"
			required
			placeholder="this song is cool because..."
			class="textarea w-full"></textarea>
	</fieldset>

	<div class="sm:col-span-2 w-full flex justify-center items-center">
		<button type="submit" class="btn">Submit</button>
	</div>
</form>

<style>
	@reference "@styles/app.css";

	.form-grid {
		gap: 0.5rem;
		padding: 0.5rem;
		max-width: 42rem;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: auto;
	}

	@media (min-width: 640px) {
		.form-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.input,
	.textarea,
	.select {
		outline: none !important;
		width: 100%;
		border-radius: 0.375rem;
		background: var(--color-bg-primary);
		border: 1px solid var(--color-border);
		color: var(--color-text-primary);
		box-shadow: var(--shadow-s);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.input:focus,
	.textarea:focus,
	.select:focus {
		border-color: var(--color-accent);
		box-shadow: 0 0 0 2px var(--color-accent-light);
	}

	.fieldset-legend {
		@apply text-2xl;
		font-family: "Faculty Glyphic", sans-serif;
		color: var(--color-text-primary);
	}

	.label {
		@apply text-sm italic;
		color: var(--color-text-muted);
	}
</style>
